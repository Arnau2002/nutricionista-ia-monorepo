# --- CONFIGURACIÓN PARA DOCKER (Creación de servicios) ---
# Esta contraseña se usará para crear la base de datos MySQL la primera vez que se levante el contenedor
MYSQL_ROOT_PASSWORD=tu_contrasena_root_aqui
MYSQL_DATABASE=precios_comparados

# --- CONFIGURACIÓN PARA CLIENTES (Python FastAPI y PHP Frontend) ---
# Docker o tu entorno local pasará estas variables a los servicios para conectar con MySQL
DB_USER=root
DB_PASS=tu_contrasena_root_aqui
# Nota: Si ejecutas fuera de Docker de forma local, cambia "db-tiendas" por "localhost"
DB_HOST=db-tiendas
DB_NAME=precios_comparados

# --- CONFIGURACIÓN DE BASE DE DATOS VECTORIAL (QDRANT) ---
# Host para el motor de búsqueda vectorial Qdrant
# Nota: Si ejecutas fuera de Docker de forma local, cambia "vector-db" por "localhost"
QDRANT_HOST=vector-db

# --- CLAVES DE API (CRÍTICO - REQUERIDO PARA FUNCIONES DE IA) ---
# Clave de API de Google Gemini (requerida por el backend para generación de menús y agente inteligente)
GOOGLE_API_KEY=tu_google_api_key_aqui

# Clave de API de Pollinations AI (requerida para generación dinámica de imágenes de platos con FLUX)
POLLINATIONS_API_KEY=tu_pollinations_api_key_aqui

# --- CONFIGURACIÓN DE GOOGLE MAPS (FRONTEND) ---
# Clave de API y Map ID para el renderizado interactivo del mapa de tiendas locales
GOOGLE_MAPS_API_KEY=tu_google_maps_api_key_aqui
MAP_ID=tu_google_maps_map_id_aqui
